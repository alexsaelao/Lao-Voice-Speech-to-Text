{
  "manifest_version": 3,
  "name": "Lao Voice - Speech to Text",
  "version": "0.1.1",
  "description": "Multilingual speech to text for any focused input.",
  "permissions": ["sidePanel", "storage"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Lao Voice - Speech to Text",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": { "default_path": "sidepanel.html" },
  "background": { "service_worker": "service-worker.js" },
  "web_accessible_resources": [
    { "resources": ["fonts/*"], "matches": ["<all_urls>"] }
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
